{
  "name": "@tailor-cms/ce-video",
  "description": "Tailor CMS video element",
  "author": "Studion <info@gostudion.com> (https://github.com/tailor-cms)",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "pnpm boot:cek",
    "boot:cek": "cd ./node_modules/@tailor-cms/tce-boot && pnpm start --default-display",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint && eslint .",
    "lint:fix": "pnpm -r run lint --fix && eslint . --fix",
    "nuke:dist": "pnpm -r run nuke:dist",
    "nuke": "pnpm -r run nuke && pnpm dlx del-cli node_modules",
    "test": "pnpm playwright test --config ./test/playwright.config.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@playwright/test": "^1.58.2",
    "@tailor-cms/cek-e2e": "^2.0.0-beta.13",
    "@tailor-cms/eslint-config": "^2.0.0-beta.13",
    "@tailor-cms/tce-boot": "^2.0.0-beta.13",
    "@types/node": "^24.0.12",
    "dotenv": "^17.1.0",
    "eslint": "^9.39.3",
    "prettier": "^3.6.2",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.12.3",
  "engines": {
    "node": ">=24"
  }
}
